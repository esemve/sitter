{
  "name": "@agentstuff/sitter",
  "version": "0.1.1",
  "description": "A TypeScript CLI tool for AI agent workflow management",
  "type": "module",
  "bin": {
    "sitter": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "ai",
    "workflow",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
