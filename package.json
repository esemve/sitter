{
  "name": "@agentstuff/sitter",
  "version": "0.1.2",
  "description": "A TypeScript CLI tool for AI agent workflow management",
  "type": "module",
  "bin": {
    "sitter": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "prepare": "npm run build",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "ai",
    "workflow",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.41",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
